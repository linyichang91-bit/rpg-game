# 复制本文件为 .env 后再填写真实值
# PowerShell:
# Copy-Item .env.example .env

# ===== LLM 网关配置 =====
# 必填：你的 API Key
LLM_API_KEY=replace_with_real_key

# 必填：兼容 OpenAI Chat Completions 的网关地址
LLM_BASE_URL=https://your-openai-compatible-gateway.example/v1

# 必填：模型名
LLM_MODEL_NAME=provider/model-name

# 可选：请求超时时间，单位秒
LLM_REQUEST_TIMEOUT_SECONDS=30

# 可选：是否优先尝试 JSON Schema 输出
LLM_JSON_SCHEMA_PREFERRED=true

# ===== 前端代理到后端引擎 =====
# Next.js 服务端路由会把 /api/* 请求转发到这里
ENGINE_API_BASE_URL=http://127.0.0.1:8000
